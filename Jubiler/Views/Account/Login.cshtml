@{
    ViewData["Title"] = "Logowanie";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 card bg-dark border-secondary p-4 shadow">
            <h2 class="text-light text-center mb-4">Zaloguj się</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger p-2">
                    @Html.ValidationSummary(true, "")
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="form-floating mb-3">
                    <input name="loginOrEmail" class="form-control bg-dark text-light border-secondary" placeholder="" required />
                    <label class="text-secondary">Login lub Email</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="password" name="password" class="form-control bg-dark text-light border-secondary" placeholder="" required />
                    <label class="text-secondary">Hasło</label>
                </div>

                <button type="submit" class="w-100 btn btn-lg btn-primary mt-3">Zaloguj</button>
            </form>
        </div>
    </div>
</div>