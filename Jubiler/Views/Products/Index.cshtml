@model IEnumerable<Jubiler.Models.Product>

@{
    ViewData["Title"] = "Index";
}

<h1>Centrum produktów</h1>

<form asp-action="Index" method="get">
    <div class="form-actions no-color">
        <p>
            Znajdź biżuterię: <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" />
            <input type="submit" value="Szukaj" class="btn btn-primary" /> 
            <a asp-action="Index" class="btn btn-secondary">Powrót do pełnej listy</a>
        </p>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Dodaj pozycje</a>
</p>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ModelName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Materials)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ModelName)
            </td>
                <td>
                    @if (item.Materials != null && item.Materials.Any())
                    {
                        @string.Join(", ", item.Materials.Select(m => m.Name))
                    }
                    else
                    {
                        <span>Brak danych</span>
                    }
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success btn-sm"><i class="bi bi-pencil-square"></i> Edit</a> 
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i> Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
